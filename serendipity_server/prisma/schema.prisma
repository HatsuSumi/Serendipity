generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                      @id @default(uuid())
  email                String?                     @unique
  phoneNumber          String?                     @unique @map("phone_number")
  passwordHash         String                      @map("password_hash")
  authProvider         String                      @default("email") @map("auth_provider") @db.VarChar(20)
  recoveryKey          String?                     @map("recovery_key")
  displayName          String?                     @map("display_name") @db.VarChar(100)
  avatarUrl            String?                     @map("avatar_url")
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")
  lastLoginAt          DateTime?                   @map("last_login_at")
  achievementUnlocks   AchievementUnlock[]
  anniversaryReminderDispatches AnniversaryReminderDispatch[]
  checkIns             CheckIn[]
  communityPosts       CommunityPost[]
  favorites            Favorite[]
  membership           Membership?
  pushTokens           PushToken[]
  records              Record[]
  refreshTokens        RefreshToken[]
  reminderDispatches   CheckInReminderDispatch[]
  storyLines           StoryLine[]
  settings             UserSettings?

  @@index([email])
  @@index([phoneNumber])
  @@map("users")
}

model Record {
  id                            String                        @id @default(uuid())
  userId                        String                        @map("user_id")
  timestamp                     DateTime
  location                      Json
  description                   String?
  tags                          Json                          @default("[]")
  emotion                       String?                       @db.VarChar(50)
  status                        String                        @db.VarChar(50)
  storyLineId                   String?                       @map("story_line_id")
  ifReencounter                 String?                       @map("if_reencounter")
  conversationStarter           String?                       @map("conversation_starter")
  backgroundMusic               String?                       @map("background_music") @db.VarChar(255)
  weather                       Json                          @default("[]")
  isPinned                      Boolean                       @default(false) @map("is_pinned")
  createdAt                     DateTime                      @map("created_at")
  updatedAt                     DateTime                      @map("updated_at")
  deletedAt                     DateTime?                     @map("deleted_at")
  anniversaryReminderDispatches AnniversaryReminderDispatch[]
  storyLine                     StoryLine?                    @relation(fields: [storyLineId], references: [id])
  user                          User                          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([updatedAt])
  @@index([deletedAt])
  @@index([storyLineId])
  @@index([timestamp])
  @@index([userId, updatedAt])
  @@map("records")
}

model StoryLine {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  name           String    @db.VarChar(255)
  recordIds Json      @default("[]") @map("record_ids")
  isPinned  Boolean   @default(false) @map("is_pinned")
  createdAt DateTime  @map("created_at")
  updatedAt DateTime  @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  records   Record[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([updatedAt])
  @@index([deletedAt])
  @@index([userId, updatedAt])
  @@map("story_lines")
}

model CommunityPost {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  recordId    String   @map("record_id")
  timestamp   DateTime
  address     String?
  placeName   String?  @map("place_name")
  placeType   String?  @map("place_type") @db.VarChar(50)
  province    String?  @db.VarChar(50)
  city        String?  @db.VarChar(100)
  area        String?  @db.VarChar(100)
  description String?
  tags        Json     @default("[]")
  status      String   @db.VarChar(50)
  publishedAt DateTime @default(now()) @map("published_at")
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([publishedAt(sort: Desc)])
  @@index([userId])
  @@index([province])
  @@index([city])
  @@index([area])
  @@index([placeType])
  @@index([status])
  @@index([userId, publishedAt(sort: Desc)])
  @@index([province, city, publishedAt(sort: Desc)])
  @@index([city, area, publishedAt(sort: Desc)])
  @@index([placeType, status, publishedAt(sort: Desc)])
  @@index([tags], type: Gin)
  @@map("community_posts")
}

model Membership {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  tier          String    @default("free") @db.VarChar(50)
  status        String    @default("inactive") @db.VarChar(50)
  startedAt     DateTime? @map("started_at")
  expiresAt     DateTime? @map("expires_at")
  monthlyAmount Int?      @map("monthly_amount")
  autoRenew     Boolean   @default(false) @map("auto_renew")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("memberships")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique @db.VarChar(255)
  deviceId  String   @map("device_id") @db.VarChar(128)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@unique([userId, expiresAt])
  @@index([userId])
  @@index([deviceId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model VerificationCode {
  id        String   @id @default(uuid())
  type      String   @db.VarChar(20)
  target    String   @db.VarChar(255)
  code      String   @db.VarChar(10)
  purpose   String   @db.VarChar(50)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([target])
  @@index([expiresAt])
  @@map("verification_codes")
}

model UserSettings {
  id                     String   @id @default(uuid())
  userId                 String   @unique @map("user_id")
  theme                  String   @default("light") @db.VarChar(50)
  pageTransition         String   @default("slide_from_right") @map("page_transition") @db.VarChar(50)
  dialogAnimation        String   @default("fade_in") @map("dialog_animation") @db.VarChar(50)
  notifications          Json     @default("{\"checkInReminder\": true, \"achievementUnlocked\": true, \"checkInReminderTime\": \"20:00\"}")
  checkIn                Json     @default("{\"confettiEnabled\": true, \"vibrationEnabled\": true}") @map("check_in")
  hasSeenCommunityIntro  Boolean  @default(false) @map("has_seen_community_intro")
  hasSeenPublishWarning  Boolean  @default(false) @map("has_seen_publish_warning")
  hasSeenFavoritesIntro  Boolean  @default(false) @map("has_seen_favorites_intro")
  hidePublishWarning     Boolean  @default(false) @map("hide_publish_warning")
  themeUpdatedAt         DateTime @default(now()) @map("theme_updated_at")
  notificationsUpdatedAt DateTime @default(now()) @map("notifications_updated_at")
  checkInUpdatedAt       DateTime @default(now()) @map("check_in_updated_at")
  communityUpdatedAt     DateTime @default(now()) @map("community_updated_at")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_settings")
}

model CheckIn {
  id        String    @id
  userId    String    @map("user_id")
  date      DateTime  @db.Date
  checkedAt DateTime  @map("checked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([deletedAt])
  @@index([userId, updatedAt])
  @@map("check_ins")
}

model Favorite {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  postId       String?  @map("post_id")
  recordId     String?  @map("record_id")
  postSnapshot Json?    @map("post_snapshot")
  recordSnapshot Json?  @map("record_snapshot")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, recordId])
  @@index([userId])
  @@index([postId])
  @@index([recordId])
  @@map("favorites")
}

model AchievementUnlock {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id") @db.VarChar(255)
  unlockedAt    DateTime @map("unlocked_at")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@map("achievement_unlocks")
}

model PushToken {
  id                            String                        @id @default(uuid())
  userId                        String                        @map("user_id")
  token                         String                        @unique
  platform                      String                        @db.VarChar(20)
  timezone                      String                        @db.VarChar(64)
  isActive                      Boolean                       @default(true) @map("is_active")
  lastUsedAt                    DateTime                      @default(now()) @map("last_used_at")
  invalidatedAt                 DateTime?                     @map("invalidated_at")
  invalidReason                 String?                       @map("invalid_reason") @db.VarChar(255)
  createdAt                     DateTime                      @default(now()) @map("created_at")
  updatedAt                     DateTime                      @updatedAt @map("updated_at")
  anniversaryReminderDispatches AnniversaryReminderDispatch[]
  user                          User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminderDispatches            CheckInReminderDispatch[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([timezone, isActive])
  @@map("push_tokens")
}

model CheckInReminderDispatch {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  pushTokenId   String    @map("push_token_id")
  reminderDate  DateTime  @db.Date @map("reminder_date")
  status        String    @db.VarChar(20)
  provider      String    @db.VarChar(20)
  failureReason String?   @map("failure_reason") @db.VarChar(255)
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  pushToken     PushToken @relation(fields: [pushTokenId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pushTokenId, reminderDate])
  @@index([userId, reminderDate])
  @@index([status, reminderDate])
  @@map("check_in_reminder_dispatches")
}

model AnniversaryReminderDispatch {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  pushTokenId   String    @map("push_token_id")
  recordId      String    @map("record_id")
  reminderDate  DateTime  @db.Date @map("reminder_date")
  status        String    @db.VarChar(20)
  provider      String    @db.VarChar(20)
  failureReason String?   @map("failure_reason") @db.VarChar(255)
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  pushToken     PushToken @relation(fields: [pushTokenId], references: [id], onDelete: Cascade)
  record        Record    @relation(fields: [recordId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pushTokenId, recordId, reminderDate])
  @@index([userId, reminderDate])
  @@index([recordId, reminderDate])
  @@index([status, reminderDate])
  @@map("anniversary_reminder_dispatches")
}
