# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://serendipity:serendipity_dev_password@localhost:5432/serendipity_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS Configuration
CORS_ORIGIN=*

# Payment Configuration
PAYMENT_MOCK_MODE=true
YUNGOUOS_MCH_ID=
YUNGOUOS_PAY_KEY=
YUNGOUOS_APP_ID=
YUNGOUOS_NOTIFY_URL=

# Check-in Reminder Configuration
CHECKIN_REMINDER_ENABLED=true
CHECKIN_REMINDER_SCAN_INTERVAL_MS=60000
CHECKIN_REMINDER_NOTIFICATION_TITLE=Check in tonight
CHECKIN_REMINDER_NOTIFICATION_BODY=Open Serendipity to complete today's check-in.

# Firebase Cloud Messaging HTTP v1 Configuration
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Apple Push Notification service Configuration
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=
APNS_PRODUCTION=false
