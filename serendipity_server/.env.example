# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://serendipity:serendipity_dev_password@localhost:5432/serendipity_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_EXPIRES_IN=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Log Configuration
LOG_LEVEL=debug

# SMS Service Configuration (Optional, for verification codes)
# SMS_ACCESS_KEY_ID=your-access-key-id
# SMS_ACCESS_KEY_SECRET=your-access-key-secret
# SMS_SIGN_NAME=Serendipity
# SMS_TEMPLATE_CODE=SMS_123456789
